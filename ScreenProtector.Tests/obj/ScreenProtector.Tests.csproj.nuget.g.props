    <Import Project="$(NuGetPackageRoot)microsoft.codecoverage/17.14.1/build/netstandard2.0/Microsoft.CodeCoverage.props" Condition="Exists('$(NuGetPackageRoot)microsoft.codecoverage/17.14.1/build/netstandard2.0/Microsoft.CodeCoverage.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.net.test.sdk/17.14.1/build/net8.0/Microsoft.NET.Test.Sdk.props" Condition="Exists('$(NuGetPackageRoot)microsoft.net.test.sdk/17.14.1/build/net8.0/Microsoft.NET.Test.Sdk.props')" />
  </ImportGroup>
  <PropertyGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <Pkgxunit_analyzers Condition=" '$(Pkgxunit_analyzers)' == '' ">/home/runner/.nuget/packages/xunit.analyzers/1.18.0</Pkgxunit_analyzers>
    <PkgMicrosoft_Windows_SDK_BuildTools_MSIX Condition=" '$(PkgMicrosoft_Windows_SDK_BuildTools_MSIX)' == '' ">/home/runner/.nuget/packages/microsoft.windows.sdk.buildtools.msix/1.7.20250829.1</PkgMicrosoft_Windows_SDK_BuildTools_MSIX>
    <PkgMicrosoft_Web_WebView2 Condition=" '$(PkgMicrosoft_Web_WebView2)' == '' ">/home/runner/.nuget/packages/microsoft.web.webview2/1.0.3179.45</PkgMicrosoft_Web_WebView2>
    <PkgMicrosoft_WindowsAppSDK_WinUI Condition=" '$(PkgMicrosoft_WindowsAppSDK_WinUI)' == '' ">/home/runner/.nuget/packages/microsoft.windowsappsdk.winui/1.8.260224000</PkgMicrosoft_WindowsAppSDK_WinUI>
    <PkgMicrosoft_WindowsAppSDK_Runtime Condition=" '$(PkgMicrosoft_WindowsAppSDK_Runtime)' == '' ">/home/runner/.nuget/packages/microsoft.windowsappsdk.runtime/1.8.260317003</PkgMicrosoft_WindowsAppSDK_Runtime>
    <PkgMicrosoft_Windows_SDK_BuildTools_WinApp Condition=" '$(PkgMicrosoft_Windows_SDK_BuildTools_WinApp)' == '' ">/home/runner/.nuget/packages/microsoft.windows.sdk.buildtools.winapp/0.3.1</PkgMicrosoft_Windows_SDK_BuildTools_WinApp>
