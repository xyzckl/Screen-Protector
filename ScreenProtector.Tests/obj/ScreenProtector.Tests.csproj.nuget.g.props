    <Import Project="$(NuGetPackageRoot)microsoft.windowsappsdk.winui/1.8.260224000/buildTransitive/Microsoft.WindowsAppSDK.WinUI.props" Condition="Exists('$(NuGetPackageRoot)microsoft.windowsappsdk.winui/1.8.260224000/buildTransitive/Microsoft.WindowsAppSDK.WinUI.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.windowsappsdk.widgets/1.8.251231004/buildTransitive/Microsoft.WindowsAppSDK.Widgets.props" Condition="Exists('$(NuGetPackageRoot)microsoft.windowsappsdk.widgets/1.8.251231004/buildTransitive/Microsoft.WindowsAppSDK.Widgets.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.windowsappsdk.runtime/1.8.260317003/buildTransitive/Microsoft.WindowsAppSDK.Runtime.props" Condition="Exists('$(NuGetPackageRoot)microsoft.windowsappsdk.runtime/1.8.260317003/buildTransitive/Microsoft.WindowsAppSDK.Runtime.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.windowsappsdk.ml/1.8.2141/buildTransitive/Microsoft.WindowsAppSDK.ML.props" Condition="Exists('$(NuGetPackageRoot)microsoft.windowsappsdk.ml/1.8.2141/buildTransitive/Microsoft.WindowsAppSDK.ML.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.windowsappsdk.dwrite/1.8.25122902/buildTransitive/Microsoft.WindowsAppSDK.DWrite.props" Condition="Exists('$(NuGetPackageRoot)microsoft.windowsappsdk.dwrite/1.8.25122902/buildTransitive/Microsoft.WindowsAppSDK.DWrite.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.windowsappsdk.ai/1.8.53/buildTransitive/Microsoft.WindowsAppSDK.AI.props" Condition="Exists('$(NuGetPackageRoot)microsoft.windowsappsdk.ai/1.8.53/buildTransitive/Microsoft.WindowsAppSDK.AI.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.windowsappsdk/1.8.260317003/buildTransitive/Microsoft.WindowsAppSDK.props" Condition="Exists('$(NuGetPackageRoot)microsoft.windowsappsdk/1.8.260317003/buildTransitive/Microsoft.WindowsAppSDK.props')" />
